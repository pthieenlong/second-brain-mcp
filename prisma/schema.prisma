// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id        String   @id @default(uuid())
  title     String
  category  String
  // SQLite has no array type. Tags are stored delimiter-wrapped (",a,b,")
  // so a LIKE ",tag," matches whole tags only. Serialized in NoteIndexService.
  tag       String   @default("")
  filePath  String   @unique
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([createdAt])
}
