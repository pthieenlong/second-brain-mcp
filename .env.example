# Absolute path to your notes vault on the host machine.
# This folder is bind-mounted into the container; notes land here as .md files.
# Example (macOS/Linux): /Users/you/Documents/SecondBrain
# Example (Windows):     C:/Users/you/Documents/SecondBrain
VAULT_PATH=/absolute/path/to/your/vault

# Categories the AI can file notes under, comma-separated.
# Notes land in VAULT_PATH/<category>/. Anything unrecognized falls back to 00-Inbox.
# Leave unset to use the defaults below.
NOTE_CATEGORIES=01-Fundamentals,02-Work,03-Product-Thinking,04-Learning,05-Career,06-Personal,07-Projects

# Postgres credentials. Change these if you expose the database beyond localhost.
POSTGRES_USER=brain
POSTGRES_PASSWORD=brainpass
POSTGRES_DB=second_brain
POSTGRES_PORT=5432

# Port the MCP server listens on (host side).
APP_PORT=3000

# Only needed when running Prisma CLI from the host (migrate dev, migrate status).
# Docker Compose sets its own DATABASE_URL for the container, pointing at the
# 'postgres' service instead of localhost.
DATABASE_URL="postgresql://brain:brainpass@localhost:5432/second_brain?schema=public"
