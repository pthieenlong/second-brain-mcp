# Only needed for local development. When running through an MCP client,
# these are passed as `env` in the client's config instead.

# Absolute path to your notes vault. The only required setting.
# The search index is created at <VAULT_PATH>/.second-brain/index.db
VAULT_PATH=/absolute/path/to/your/vault

# Categories the AI can file notes under, comma-separated.
# Anything unrecognized falls back to 00-Inbox. Leave unset for the defaults.
# NOTE_CATEGORIES=01-Fundamentals,02-Work,03-Product-Thinking,04-Learning,05-Career,06-Personal,07-Projects

# Override where the index file lives. Defaults to the path above.
# DATABASE_URL="file:./dev.db"
